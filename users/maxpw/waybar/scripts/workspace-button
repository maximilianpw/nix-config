#!/usr/bin/env sh
set -eu

id="${1:?workspace id required}"
class="empty"

if command -v hyprctl >/dev/null 2>&1 && command -v jq >/dev/null 2>&1; then
  active_id="$(hyprctl activeworkspace -j 2>/dev/null | jq -r '.id // empty')"
  windows="$(hyprctl workspaces -j 2>/dev/null | jq -r --argjson id "$id" '.[] | select(.id == $id) | .windows' | head -n 1)"

  if [ "$active_id" = "$id" ]; then
    class="active"
  elif [ "${windows:-0}" != "0" ]; then
    class="persistent"
  fi
fi

if command -v jq >/dev/null 2>&1; then
  jq -cn --arg text "$id" --arg class "$class" '{text: $text, class: $class}'
else
  printf '{"text":"%s","class":"%s"}\n' "$id" "$class"
fi
