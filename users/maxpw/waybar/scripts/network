#!/usr/bin/env bash
set -u

# Waybar port of Omarchy's native network panel:
# https://github.com/basecamp/omarchy/tree/1b6ab15331bfc88eb66746021d9e32c976ed438a/shell/plugins/panels/network
#
# DNS is intentionally read-only here. NixOS owns NetworkManager and
# systemd-resolved configuration, so runtime edits to /etc would cause drift.

internet_probe="1.1.1.1"
waybar_signal=9
ping_history_size=10
speed_test_seconds=5
speed_test_workers=8
connectivity_sample_interval=30

runtime_base="${XDG_RUNTIME_DIR:-/tmp}"
runtime_user="${UID:-$(id -u)}"
cache_dir="$runtime_base/waybar-network-$runtime_user"
mkdir -p "$cache_dir"
chmod 700 "$cache_dir" 2>/dev/null || true

notify() {
  if command -v notify-send >/dev/null 2>&1; then
    notify-send -a "Network" "$1" "$2"
  fi
}

refresh_waybar() {
  pkill "-RTMIN+$waybar_signal" -x waybar 2>/dev/null || true
}

copy_value() {
  local value="$1"
  local label="$2"

  if [[ -z "$value" ]]; then
    notify "Network" "No $label is available"
    return
  fi

  if ! command -v wl-copy >/dev/null 2>&1; then
    notify "Network" "wl-copy is required for clipboard actions"
    return
  fi

  printf '%s' "$value" | wl-copy
  notify "Network" "Copied $label"
}

human_bytes() {
  awk -v bytes="${1:-0}" 'BEGIN {
    if (bytes < 1024) printf "%.0f B", bytes
    else if (bytes < 1048576) printf "%.1f KiB", bytes / 1024
    else if (bytes < 1073741824) printf "%.1f MiB", bytes / 1048576
    else printf "%.2f GiB", bytes / 1073741824
  }'
}

human_rate() {
  printf '%s/s' "$(human_bytes "${1:-0}")"
}

wifi_icon() {
  local strength="${1:-0}"

  if ((strength >= 75)); then
    printf '󰤨'
  elif ((strength >= 50)); then
    printf '󰤥'
  elif ((strength >= 25)); then
    printf '󰤢'
  elif ((strength > 0)); then
    printf '󰤟'
  else
    printf '󰤯'
  fi
}

link_speed_label() {
  local speed="${1:-}"

  if [[ ! "$speed" =~ ^[0-9]+$ ]] || ((speed <= 0)); then
    return
  fi

  if ((speed >= 1000)); then
    awk -v speed="$speed" 'BEGIN {
      value = speed / 1000
      if (value == int(value)) printf "%.0f Gbit/s", value
      else printf "%.1f Gbit/s", value
    }'
  else
    printf '%s Mbit/s' "$speed"
  fi
}

frequency_label() {
  local frequency="${1:-}"

  if [[ ! "$frequency" =~ ^[0-9]+([.][0-9]+)?$ ]]; then
    return
  fi

  awk -v frequency="$frequency" 'BEGIN {
    if (frequency >= 2400 && frequency < 2500) print "2.4 GHz"
    else if (frequency >= 4900 && frequency < 5925) print "5 GHz"
    else if (frequency >= 5925 && frequency < 7125) print "6 GHz"
    else printf "%.1f GHz", frequency / 1000
  }'
}

read_counter() {
  local iface="$1"
  local counter="$2"
  local path="/sys/class/net/$iface/statistics/$counter"

  if [[ -r "$path" ]]; then
    read -r value <"$path"
    printf '%s' "${value:-0}"
  else
    printf '0'
  fi
}

route_json() {
  ip -j route get "$internet_probe" 2>/dev/null || true
}

wifi_device() {
  nmcli -t -f DEVICE,TYPE device status 2>/dev/null |
    awk -F: '$2 == "wifi" { print $1; exit }'
}

dns_details() {
  local iface="$1"
  local servers=""
  local provider="DHCP / automatic"

  if command -v resolvectl >/dev/null 2>&1; then
    servers="$(
      resolvectl dns "$iface" 2>/dev/null |
        sed -n 's/^[^:]*:[[:space:]]*//p' |
        head -n 1
    )"
  fi

  if [[ -z "$servers" ]]; then
    servers="$(
      nmcli -g IP4.DNS device show "$iface" 2>/dev/null |
        paste -sd ' ' -
    )"
  fi

  case " $servers " in
    *" 1.1.1.1 "* | *" 1.0.0.1 "*)
      provider="Cloudflare"
      ;;
    *" 8.8.8.8 "* | *" 8.8.4.4 "*)
      provider="Google"
      ;;
  esac

  dns_servers="$servers"
  dns_provider="$provider"
}

collect_network() {
  local route
  local address_json
  local connection

  iface=""
  gateway=""
  ip_address=""
  prefix=""
  connection_name=""
  connection_type="disconnected"
  ssid=""
  signal_strength="0"
  frequency=""
  link_speed=""
  duplex=""
  rx_bytes="0"
  tx_bytes="0"
  download_rate="0"
  upload_rate="0"
  dns_servers=""
  dns_provider=""

  route="$(route_json)"
  if ! jq -e 'type == "array" and length > 0 and .[0].dev' <<<"$route" >/dev/null 2>&1; then
    return 1
  fi

  iface="$(jq -r '.[0].dev // empty' <<<"$route")"
  gateway="$(jq -r '.[0].gateway // empty' <<<"$route")"
  ip_address="$(jq -r '.[0].prefsrc // empty' <<<"$route")"

  if [[ -z "$iface" ]]; then
    return 1
  fi

  address_json="$(ip -j address show dev "$iface" 2>/dev/null || true)"
  prefix="$(
    jq -r '
      .[0].addr_info[]?
      | select(.family == "inet" and .scope == "global")
      | .prefixlen
    ' <<<"$address_json" 2>/dev/null | head -n 1
  )"
  if [[ -z "$ip_address" ]]; then
    ip_address="$(
      jq -r '
        .[0].addr_info[]?
        | select(.family == "inet" and .scope == "global")
        | .local
      ' <<<"$address_json" 2>/dev/null | head -n 1
    )"
  fi

  connection="$(
    nmcli -g GENERAL.CONNECTION device show "$iface" 2>/dev/null |
      head -n 1
  )"
  connection_name="${connection:---}"

  if [[ -d "/sys/class/net/$iface/wireless" ]]; then
    connection_type="wifi"
    ssid="$(
      nmcli -g 802-11-wireless.ssid connection show "$connection_name" 2>/dev/null |
        head -n 1
    )"
    ssid="${ssid:-$connection_name}"
    signal_strength="$(
      nmcli -t -f IN-USE,SIGNAL device wifi list ifname "$iface" --rescan no 2>/dev/null |
        awk -F: '$1 == "*" { print $2; exit }'
    )"
    signal_strength="${signal_strength:-0}"
    frequency="$(
      nmcli -t -f IN-USE,FREQ device wifi list ifname "$iface" --rescan no 2>/dev/null |
        awk -F: '$1 == "*" { print $2; exit }'
    )"
    link_speed="$(cat "/sys/class/net/$iface/speed" 2>/dev/null || true)"
  else
    connection_type="ethernet"
    link_speed="$(cat "/sys/class/net/$iface/speed" 2>/dev/null || true)"
    duplex="$(cat "/sys/class/net/$iface/duplex" 2>/dev/null || true)"
  fi

  rx_bytes="$(read_counter "$iface" rx_bytes)"
  tx_bytes="$(read_counter "$iface" tx_bytes)"
  calculate_rates
  dns_details "$iface"
  return 0
}

calculate_rates() {
  local state_file="$cache_dir/throughput"
  local state_tmp="$cache_dir/throughput.$$"
  local previous_iface=""
  local previous_rx="0"
  local previous_tx="0"
  local previous_time="0"
  local now
  local elapsed

  now="$(date +%s)"
  if [[ -r "$state_file" ]]; then
    read -r previous_iface previous_rx previous_tx previous_time <"$state_file" || true
  fi

  if [[ "$previous_iface" == "$iface" ]] &&
    [[ "$previous_rx" =~ ^[0-9]+$ ]] &&
    [[ "$previous_tx" =~ ^[0-9]+$ ]] &&
    [[ "$previous_time" =~ ^[0-9]+$ ]] &&
    ((now > previous_time)); then
    elapsed=$((now - previous_time))
    if ((rx_bytes >= previous_rx)); then
      download_rate=$(((rx_bytes - previous_rx) / elapsed))
    fi
    if ((tx_bytes >= previous_tx)); then
      upload_rate=$(((tx_bytes - previous_tx) / elapsed))
    fi
  fi

  printf '%s %s %s %s\n' "$iface" "$rx_bytes" "$tx_bytes" "$now" >"$state_tmp"
  mv "$state_tmp" "$state_file"
}

ping_latency() {
  local host="$1"

  LC_ALL=C ping -n -c 1 -W 1 "$host" 2>/dev/null |
    awk -F'time[=<]' '/time[=<]/ {
      split($2, parts, " ")
      print parts[1]
      exit
    }'
}

append_ping_sample() {
  local history_file="$1"
  local sample="${2:-timeout}"
  local history_tmp="$history_file.$$"

  {
    [[ -r "$history_file" ]] && cat "$history_file"
    printf '%s\n' "${sample:-timeout}"
  } | tail -n "$ping_history_size" >"$history_tmp"
  mv "$history_tmp" "$history_file"
}

ping_summary() {
  local history_file="$1"

  if [[ ! -s "$history_file" ]]; then
    printf '%s\t%s\t%s\n' "--" "0" "0"
    return
  fi

  awk '
    BEGIN { total = 0; success = 0; count = 0 }
    {
      count++
      if ($1 ~ /^[0-9]+([.][0-9]+)?$/) {
        total += $1
        success++
      }
    }
    END {
      if (success > 0) {
        average = total / success
        if (average < 10) latency = sprintf("%.1f ms", average)
        else latency = sprintf("%.0f ms", average)
      } else {
        latency = "Timeout"
      }
      loss = count > 0 ? int(((count - success) * 100 / count) + 0.5) : 0
      printf "%s\t%d\t%d\n", latency, loss, count
    }
  ' "$history_file"
}

connectivity_paths() {
  local safe_iface

  safe_iface="${iface//[^[:alnum:]_.-]/_}"
  router_history="$cache_dir/ping-$safe_iface-router"
  internet_history="$cache_dir/ping-$safe_iface-internet"
  connectivity_timestamp="$cache_dir/ping-$safe_iface-timestamp"
}

load_connectivity_summary() {
  router_latency="--"
  router_loss="0"
  router_samples="0"
  internet_latency="--"
  internet_loss="0"
  internet_samples="0"

  [[ -n "$iface" ]] || return
  connectivity_paths

  if [[ -n "$gateway" ]]; then
    IFS=$'\t' read -r router_latency router_loss router_samples < <(
      ping_summary "$router_history"
    )
  fi
  IFS=$'\t' read -r internet_latency internet_loss internet_samples < <(
    ping_summary "$internet_history"
  )
}

sample_connectivity() {
  local sample_dir
  local router_sample=""
  local internet_sample=""

  [[ -n "$iface" ]] || {
    load_connectivity_summary
    return
  }

  connectivity_paths
  sample_dir="$(mktemp -d "$cache_dir/ping.XXXXXX")" || return

  if [[ -n "$gateway" ]]; then
    ping_latency "$gateway" >"$sample_dir/router" &
    router_pid=$!
  else
    router_pid=""
  fi
  ping_latency "$internet_probe" >"$sample_dir/internet" &
  internet_pid=$!

  if [[ -n "$router_pid" ]]; then
    wait "$router_pid" || true
    router_sample="$(cat "$sample_dir/router" 2>/dev/null || true)"
    append_ping_sample "$router_history" "$router_sample"
  fi
  wait "$internet_pid" || true
  internet_sample="$(cat "$sample_dir/internet" 2>/dev/null || true)"
  append_ping_sample "$internet_history" "$internet_sample"
  rm -r "$sample_dir"
  date +%s >"$connectivity_timestamp"

  load_connectivity_summary
}

maybe_sample_connectivity() {
  local last_sample="0"
  local now

  connectivity_paths
  if [[ -r "$connectivity_timestamp" ]]; then
    read -r last_sample <"$connectivity_timestamp" || true
  fi
  now="$(date +%s)"

  if [[ ! "$last_sample" =~ ^[0-9]+$ ]] ||
    ((now - last_sample >= connectivity_sample_interval)); then
    sample_connectivity
  else
    load_connectivity_summary
  fi
}

last_speed_test() {
  local result_file="$cache_dir/speedtest-result"

  if [[ -r "$result_file" ]]; then
    cat "$result_file"
  fi
}

details_text() {
  local details=""
  local link_detail=""
  local last_test

  if [[ -z "$iface" ]]; then
    printf 'Disconnected'
    return
  fi

  if [[ "$connection_type" == "wifi" ]]; then
    link_detail="$(frequency_label "$frequency")"
    details="Wi-Fi · $ssid · ${signal_strength}%"
    if [[ -n "$(link_speed_label "$link_speed")" ]]; then
      link_detail="${link_detail:+$link_detail · }$(link_speed_label "$link_speed")"
    fi
  else
    link_detail="$(link_speed_label "$link_speed")"
    details="Ethernet · $connection_name"
    [[ -n "$duplex" ]] && link_detail="${link_detail:+$link_detail · }$duplex duplex"
  fi

  [[ -n "$link_detail" ]] && details+=" · $link_detail"
  details+=$'\n\n'
  details+="Interface  $iface"$'\n'
  details+="IPv4       ${ip_address:-—}"
  [[ -n "$prefix" ]] && details+="/$prefix"
  details+=$'\n'
  details+="Gateway    ${gateway:-—}"$'\n'
  details+="DNS        ${dns_provider:-Unknown}"
  [[ -n "$dns_servers" ]] && details+=" · $dns_servers"
  details+=$'\n\n'
  details+="Download   $(human_rate "$download_rate")"$'\n'
  details+="Upload     $(human_rate "$upload_rate")"$'\n'
  details+="Received   $(human_bytes "$rx_bytes")"$'\n'
  details+="Sent       $(human_bytes "$tx_bytes")"$'\n\n'
  details+="Router     $router_latency"
  [[ "$router_samples" -gt 0 ]] && details+=" · ${router_loss}% loss"
  details+=$'\n'
  details+="Internet   $internet_latency · ${internet_loss}% loss"

  last_test="$(last_speed_test)"
  if [[ -n "$last_test" ]]; then
    details+=$'\n\n'
    details+="Last speed test  $last_test"
  fi

  printf '%s' "$details"
}

print_disconnected() {
  local wifi_state="unavailable"
  local class="disconnected"
  local icon="󰤯"
  local tooltip="Network: Disconnected"

  if command -v nmcli >/dev/null 2>&1; then
    wifi_state="$(nmcli radio wifi 2>/dev/null || true)"
  fi
  if [[ "$wifi_state" == "disabled" ]]; then
    class="disabled"
    icon="󰤮"
    tooltip="Network: Wi-Fi disabled"
  fi

  jq -cn \
    --arg text "$icon" \
    --arg tooltip "$tooltip"$'\n'"Left-click for network actions" \
    --arg class "$class" \
    '{text: $text, tooltip: $tooltip, class: $class, alt: $class}'
}

print_status() {
  local icon
  local class
  local tooltip

  if ! command -v jq >/dev/null 2>&1 ||
    ! command -v ip >/dev/null 2>&1 ||
    ! command -v nmcli >/dev/null 2>&1; then
    jq -cn \
      --arg text "󰤮" \
      --arg tooltip "Network status dependencies are unavailable" \
      '{text: $text, tooltip: $tooltip, class: "unavailable", alt: "unavailable"}' 2>/dev/null ||
      printf '{"text":"󰤮","tooltip":"Network unavailable","class":"unavailable","alt":"unavailable"}\n'
    return
  fi

  if ! collect_network; then
    print_disconnected
    return
  fi

  maybe_sample_connectivity
  if [[ "$connection_type" == "wifi" ]]; then
    icon="$(wifi_icon "$signal_strength")"
    class="wifi"
  else
    icon="󰈀"
    class="ethernet"
  fi

  if ((internet_samples >= 3 && internet_loss == 100)); then
    class="no-internet"
  fi

  tooltip="$(details_text)"
  tooltip+=$'\n\n'
  tooltip+="Left-click: network panel"$'\n'
  tooltip+="Right-click: connection editor"

  jq -cn \
    --arg text "$icon" \
    --arg tooltip "$tooltip" \
    --arg class "$class" \
    '{text: $text, tooltip: $tooltip, class: $class, alt: $class}'
}

show_details() {
  if collect_network; then
    sample_connectivity
    rofi -e "$(details_text)"
  else
    rofi -e "Network disconnected"
  fi
}

wifi_rows() {
  local device="$1"

  nmcli -t -e yes -f IN-USE,SIGNAL,SECURITY,SSID \
    device wifi list ifname "$device" --rescan yes 2>/dev/null |
    awk '
      function split_escaped(line, fields,    i, char, escaped, count) {
        count = 1
        fields[count] = ""
        escaped = 0
        for (i = 1; i <= length(line); i++) {
          char = substr(line, i, 1)
          if (escaped) {
            fields[count] = fields[count] char
            escaped = 0
          } else if (char == "\\") {
            escaped = 1
          } else if (char == ":") {
            count++
            fields[count] = ""
          } else {
            fields[count] = fields[count] char
          }
        }
        return count
      }
      {
        delete fields
        count = split_escaped($0, fields)
        if (count >= 4 && fields[4] != "") {
          active = fields[1] == "*" ? 1 : 0
          printf "%d\t%s\t%s\t%s\n", active, fields[2], fields[3], fields[4]
        }
      }
    '
}

choose_wifi() {
  local device
  local rows_file
  local menu_file
  local map_file
  local active
  local strength
  local security
  local network_ssid
  local marker
  local label
  local index
  local selected
  local password
  local output

  device="$(wifi_device)"
  if [[ -z "$device" ]]; then
    notify "Network" "No Wi-Fi adapter is available"
    return
  fi

  rows_file="$(mktemp "$cache_dir/wifi-rows.XXXXXX")" || return
  menu_file="$(mktemp "$cache_dir/wifi-menu.XXXXXX")" || {
    rm -f "$rows_file"
    return
  }
  map_file="$(mktemp "$cache_dir/wifi-map.XXXXXX")" || {
    rm -f "$rows_file" "$menu_file"
    return
  }

  wifi_rows "$device" >"$rows_file"
  while IFS=$'\t' read -r active strength security network_ssid; do
    [[ -n "$network_ssid" ]] || continue
    marker="  "
    [[ "$active" == "1" ]] && marker="● "
    label="$marker$(wifi_icon "$strength")  $network_ssid  ${strength}%"
    [[ -n "$security" && "$security" != "--" ]] && label+="  󰌾"
    printf '%s\n' "$label" >>"$menu_file"
    printf '%s\t%s\t%s\n' "$active" "$network_ssid" "$security" >>"$map_file"
  done <"$rows_file"

  if [[ ! -s "$menu_file" ]]; then
    notify "Network" "No Wi-Fi networks were found"
    rm -f "$rows_file" "$menu_file" "$map_file"
    return
  fi

  index="$(rofi -dmenu -i -p "Wi-Fi network" -format i <"$menu_file" || true)"
  if [[ ! "$index" =~ ^[0-9]+$ ]]; then
    rm -f "$rows_file" "$menu_file" "$map_file"
    return
  fi

  selected="$(sed -n "$((index + 1))p" "$map_file")"
  IFS=$'\t' read -r active network_ssid security <<<"$selected"

  if [[ "$active" == "1" ]]; then
    if nmcli device disconnect "$device" >/dev/null 2>&1; then
      notify "Network" "Disconnected $network_ssid"
    else
      notify "Network" "Could not disconnect $network_ssid"
    fi
  elif output="$(nmcli --wait 15 device wifi connect "$network_ssid" ifname "$device" 2>&1)"; then
    notify "Network" "Connected to $network_ssid"
  elif [[ -n "$security" && "$security" != "--" ]]; then
    password="$(
      printf '' |
        rofi -dmenu -password -p "Passphrase for $network_ssid" || true
    )"
    if [[ -n "$password" ]] &&
      output="$(
        nmcli --wait 20 device wifi connect "$network_ssid" \
          password "$password" ifname "$device" 2>&1
      )"; then
      notify "Network" "Connected to $network_ssid"
    elif [[ -n "$password" ]]; then
      notify "Wi-Fi connection failed" "${output:-Unknown NetworkManager error}"
    fi
  else
    notify "Wi-Fi connection failed" "${output:-Unknown NetworkManager error}"
  fi

  rm -f "$rows_file" "$menu_file" "$map_file"
  refresh_waybar
}

toggle_wifi() {
  local state

  state="$(nmcli radio wifi 2>/dev/null || true)"
  if [[ "$state" == "enabled" ]]; then
    nmcli radio wifi off
    notify "Network" "Wi-Fi disabled"
  else
    nmcli radio wifi on
    notify "Network" "Wi-Fi enabled"
  fi
  refresh_waybar
}

disconnect_wifi() {
  if [[ -n "$iface" ]] && nmcli device disconnect "$iface" >/dev/null 2>&1; then
    notify "Network" "Disconnected $ssid"
  else
    notify "Network" "Could not disconnect the Wi-Fi network"
  fi
  refresh_waybar
}

stop_workers() {
  local pid

  for pid in "${traffic_pids[@]:-}"; do
    [[ -n "$pid" ]] || continue
    pkill -TERM -P "$pid" 2>/dev/null || true
    kill "$pid" 2>/dev/null || true
  done
  for pid in "${traffic_pids[@]:-}"; do
    [[ -n "$pid" ]] || continue
    wait "$pid" 2>/dev/null || true
  done
  traffic_pids=()
}

traffic_worker() {
  local direction="$1"
  shift
  local urls=("$@")
  local count="${#urls[@]}"
  local index="$RANDOM"
  local url

  while true; do
    url="${urls[$((index % count))]}"
    if [[ "$direction" == "down" ]]; then
      curl -fsS -o /dev/null "$url" 2>/dev/null || return
    else
      dd if=/dev/zero bs=1M count=64 2>/dev/null |
        curl -fsS -o /dev/null -X POST --data-binary @- "$url" 2>/dev/null ||
        return
    fi
    index=$((index + 1))
  done
}

measure_speed() {
  local direction="$1"
  shift
  local urls=("$@")
  local counter="rx_bytes"
  local before
  local after
  local delta
  local worker

  [[ "$direction" == "up" ]] && counter="tx_bytes"
  traffic_pids=()
  before="$(read_counter "$iface" "$counter")"

  for ((worker = 0; worker < speed_test_workers; worker++)); do
    traffic_worker "$direction" "${urls[@]}" &
    traffic_pids+=("$!")
  done

  sleep "$speed_test_seconds"
  after="$(read_counter "$iface" "$counter")"
  stop_workers

  delta=0
  if ((after >= before)); then
    delta=$((after - before))
  fi
  awk -v bytes="$delta" -v seconds="$speed_test_seconds" 'BEGIN {
    mbps = bytes * 8 / seconds / 1000000
    if (mbps < 10) printf "%.1f", mbps
    else printf "%.0f", mbps
  }'
}

run_speed_test() {
  local lock_dir="$cache_dir/speedtest.lock"
  local fast_token="YXNkZmFzZGxmbnNkYWZoYXNkZmhrYWxm"
  local fast_api_url
  local endpoint_json
  local urls=()
  local download
  local upload
  local result

  if ! mkdir "$lock_dir" 2>/dev/null; then
    notify "Speed test" "A speed test is already running"
    return
  fi

  (
    trap 'rmdir "$lock_dir" 2>/dev/null || true' EXIT

    if ! collect_network; then
      notify "Speed test failed" "No active network interface"
      exit
    fi
    if ! command -v curl >/dev/null 2>&1; then
      notify "Speed test failed" "curl is required"
      exit
    fi

    notify "Speed test" "Testing download and upload for ${speed_test_seconds}s each…"
    fast_api_url="https://api.fast.com/netflix/speedtest/v2?https=true&token=$fast_token&urlCount=3"
    endpoint_json="$(curl -fsS "$fast_api_url" 2>/dev/null || true)"
    mapfile -t urls < <(jq -r '.targets[]?.url // empty' <<<"$endpoint_json" 2>/dev/null)
    if ((${#urls[@]} == 0)); then
      notify "Speed test failed" "Could not fetch Fast.com endpoints"
      exit
    fi

    download="$(measure_speed down "${urls[@]}")"
    upload="$(measure_speed up "${urls[@]}")"
    result="↓ ${download} Mbps · ↑ ${upload} Mbps"
    printf '%s · %s\n' "$result" "$(date '+%Y-%m-%d %H:%M')" >"$cache_dir/speedtest-result"
    notify "Speed test complete" "$result"
    refresh_waybar
  ) </dev/null >/dev/null 2>&1 &
}

open_connection_editor() {
  if command -v nm-connection-editor >/dev/null 2>&1; then
    nm-connection-editor >/dev/null 2>&1 &
  else
    notify "Network" "nm-connection-editor is unavailable"
  fi
}

show_menu() {
  local options=""
  local choice
  local wifi_adapter
  local wifi_state

  if ! command -v rofi >/dev/null 2>&1; then
    notify "Network" "rofi is required for the network panel"
    return
  fi

  collect_network || true
  wifi_adapter="$(wifi_device)"
  wifi_state="$(nmcli radio wifi 2>/dev/null || true)"

  options="Connection details"
  [[ -n "$ip_address" ]] && options+=$'\n'"Copy IP address"
  [[ -n "$gateway" ]] && options+=$'\n'"Copy gateway"
  [[ -n "$iface" ]] && options+=$'\n'"Run speed test"

  if [[ -n "$wifi_adapter" ]]; then
    if [[ "$wifi_state" == "enabled" ]]; then
      options+=$'\n'"Choose Wi-Fi network"
      options+=$'\n'"Turn Wi-Fi off"
    else
      options+=$'\n'"Turn Wi-Fi on"
    fi
  fi
  if [[ "$connection_type" == "wifi" ]]; then
    options+=$'\n'"Disconnect $ssid"
  fi

  options+=$'\n'"Open connection editor"
  options+=$'\n'"Refresh"

  choice="$(printf '%s\n' "$options" | rofi -dmenu -i -p "Network" || true)"
  case "$choice" in
    "Connection details")
      show_details
      ;;
    "Copy IP address")
      copy_value "$ip_address" "IP address"
      ;;
    "Copy gateway")
      copy_value "$gateway" "gateway"
      ;;
    "Run speed test")
      run_speed_test
      ;;
    "Choose Wi-Fi network")
      choose_wifi
      ;;
    "Turn Wi-Fi off" | "Turn Wi-Fi on")
      toggle_wifi
      ;;
    Disconnect\ *)
      disconnect_wifi
      ;;
    "Open connection editor")
      open_connection_editor
      ;;
    "Refresh")
      refresh_waybar
      ;;
  esac
}

main() {
  case "${1:-status}" in
    status)
      print_status
      ;;
    menu)
      show_menu
      ;;
    details)
      if collect_network; then
        sample_connectivity
        details_text
        printf '\n'
      else
        printf 'Disconnected\n'
      fi
      ;;
    speedtest)
      run_speed_test
      ;;
    editor)
      open_connection_editor
      ;;
    refresh)
      refresh_waybar
      ;;
    *)
      printf 'Usage: %s {status|menu|details|speedtest|editor|refresh}\n' "$0" >&2
      exit 2
      ;;
  esac
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
  main "$@"
fi
